\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces  \textbf  {Width controls feature-kernel stability.} (a) CKA$(K_{0},K_{T})$ as a function of width. At width 1024, CKA exceeds 0.999 across all tasks. At width 32, CKA drops to 0.85--0.99 depending on the target. (b) Normalized Frobenius change $\|K_{T}-K_{0}\|_{F}/\|K_{0}\|_{F}$. At width 1024, poly and highfreq drop to $\sim $1\%. At width 32, it reaches 25--103\% depending on the target. Error bars show $\pm 1$ s.d. over 10 seeds. }}{8}{figure.caption.2}\protected@file@percent }
\newlabel{fig:stability}{{1}{8}{\textbf {Width controls feature-kernel stability.} (a) CKA$(K_{0},K_{T})$ as a function of width. At width 1024, CKA exceeds 0.999 across all tasks. At width 32, CKA drops to 0.85--0.99 depending on the target. (b) Normalized Frobenius change $\|K_{T}-K_{0}\|_{F}/\|K_{0}\|_{F}$. At width 1024, poly and highfreq drop to $\sim $1\%. At width 32, it reaches 25--103\% depending on the target. Error bars show $\pm 1$ s.d. over 10 seeds}{figure.caption.2}{}}
