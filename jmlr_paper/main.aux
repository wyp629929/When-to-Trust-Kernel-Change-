\@writefile{lof}{\contentsline {figure}{\numberline {S1}{\ignorespaces Spectral redistribution. For each dataset at width 128, top panels show eigenvalue ratio $\lambda _{\text  {post}}/\lambda _{\text  {init}}$ per eigen-direction; bottom panels show target projections $v_{i}$ before and after training. GMM exhibits substantial reorganization in both quantities despite high CKA.}}{28}{figure.caption.11}\protected@file@percent }
\newlabel{fig:spec_redist}{{S1}{28}{Spectral redistribution. For each dataset at width 128, top panels show eigenvalue ratio $\lambda _{\text {post}}/\lambda _{\text {init}}$ per eigen-direction; bottom panels show target projections $v_{i}$ before and after training. GMM exhibits substantial reorganization in both quantities despite high CKA}{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S2}{\ignorespaces MNIST dissociation. Kernel change versus generalization improvement for MNIST binary classification (0 vs.\ 1). The association is moderate (Spearman $\rho =0.66$, $p<0.001$), indicating that the dissociation is less extreme on real data: kernel change carries \emph  {some} predictive signal but remains incomplete as a sufficient diagnostic.}}{29}{figure.caption.12}\protected@file@percent }
\newlabel{fig:mnist_scatter}{{S2}{29}{MNIST dissociation. Kernel change versus generalization improvement for MNIST binary classification (0 vs.\ 1). The association is moderate (Spearman $\rho =0.66$, $p<0.001$), indicating that the dissociation is less extreme on real data: kernel change carries \emph {some} predictive signal but remains incomplete as a sufficient diagnostic}{figure.caption.12}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S1}{\ignorespaces CIFAR-10 CNN results (5 seeds per width). Values are means $\pm $ s.d. The linear probe $\Delta R^2$ is numerically largest at $W=32$ ($+0.519\pm 0.306$, comparable to $W=64$ at $+0.509\pm 0.321$ within one standard deviation) while Frobenius change shows a non-monotonic pattern.}}{29}{table.caption.16}\protected@file@percent }
\newlabel{tab:cnn_cifar}{{S1}{29}{CIFAR-10 CNN results (5 seeds per width). Values are means $\pm $ s.d. The linear probe $\Delta R^2$ is numerically largest at $W=32$ ($+0.519\pm 0.306$, comparable to $W=64$ at $+0.509\pm 0.321$ within one standard deviation) while Frobenius change shows a non-monotonic pattern}{table.caption.16}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S3}{\ignorespaces CKA versus SVCCA across all configurations (10 seeds per condition). Points are colored by dataset. The two metrics show strong agreement (pooled Spearman $\rho =0.89$, $p<0.001$), confirming that the dissociation documented with CKA is not specific to one metric choice.}}{30}{figure.caption.13}\protected@file@percent }
\newlabel{fig:cka_vs_svcca}{{S3}{30}{CKA versus SVCCA across all configurations (10 seeds per condition). Points are colored by dataset. The two metrics show strong agreement (pooled Spearman $\rho =0.89$, $p<0.001$), confirming that the dissociation documented with CKA is not specific to one metric choice}{figure.caption.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S4}{\ignorespaces Training dynamics for poly, width 32 (illustrative single-seed trajectory). Test error drops while CKA (right axis) stabilizes within 50 epochs. Across 10 seeds, the mean improvement is $0.003\pm 0.049$ (Table~\ref {tab:results}), so this trajectory shows the temporal decoupling mechanism rather than the typical effect size.}}{30}{figure.caption.14}\protected@file@percent }
\newlabel{fig:epoch}{{S4}{30}{Training dynamics for poly, width 32 (illustrative single-seed trajectory). Test error drops while CKA (right axis) stabilizes within 50 epochs. Across 10 seeds, the mean improvement is $0.003\pm 0.049$ (Table~\ref {tab:results}), so this trajectory shows the temporal decoupling mechanism rather than the typical effect size}{figure.caption.14}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S5}{\ignorespaces CNN eigenvalue spectrum evolution on CIFAR-10 before (blue) and after (orange) training, for channel widths $W=16$ (left) and $W=128$ (right). At $W=128$, the top eigenvalues increase substantially after training while the rank order is preserved, confirming that spectral reorganization persists even when CKA is high ($0.991$).}}{31}{figure.caption.15}\protected@file@percent }
\newlabel{fig:cnn_spectrum}{{S5}{31}{CNN eigenvalue spectrum evolution on CIFAR-10 before (blue) and after (orange) training, for channel widths $W=16$ (left) and $W=128$ (right). At $W=128$, the top eigenvalues increase substantially after training while the rank order is preserved, confirming that spectral reorganization persists even when CKA is high ($0.991$)}{figure.caption.15}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S2}{\ignorespaces MNIST binary classification (0 vs.\ 1). Width-dependent kernel stability shows a non-monotonic pattern: CKA rises from 0.768 to 0.963 as width increases from 32 to 256, then \emph  {declines} at width 1024 ($0.867\pm 0.024$, consistent across all 5 seeds). The Frobenius change similarly increases at width 1024 ($81.5\pm 9.3\%$), suggesting that on high-dimensional inputs (784D) very wide networks enter a distinct optimization regime where the kernel continues to reorganize substantially. The cause of this reversal is not yet established but appears robust across seeds. Despite these variations, the dissociation between $\Delta K$ and generalization improvement persists (Spearman $\rho =0.66$, $p<0.001$; see Supplementary Figure~S2).}}{31}{table.caption.17}\protected@file@percent }
\newlabel{tab:mnist}{{S2}{31}{MNIST binary classification (0 vs.\ 1). Width-dependent kernel stability shows a non-monotonic pattern: CKA rises from 0.768 to 0.963 as width increases from 32 to 256, then \emph {declines} at width 1024 ($0.867\pm 0.024$, consistent across all 5 seeds). The Frobenius change similarly increases at width 1024 ($81.5\pm 9.3\%$), suggesting that on high-dimensional inputs (784D) very wide networks enter a distinct optimization regime where the kernel continues to reorganize substantially. The cause of this reversal is not yet established but appears robust across seeds. Despite these variations, the dissociation between $\Delta K$ and generalization improvement persists (Spearman $\rho =0.66$, $p<0.001$; see Supplementary Figure~S2)}{table.caption.17}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S3}{\ignorespaces Linear probe R$^2$ on frozen features (mean over 5 seeds). Poly features improve most when kernel change is large. Highfreq features degrade after training despite $>90\%$ kernel change.}}{32}{table.caption.18}\protected@file@percent }
\newlabel{tab:linear_probe}{{S3}{32}{Linear probe R$^2$ on frozen features (mean over 5 seeds). Poly features improve most when kernel change is large. Highfreq features degrade after training despite $>90\%$ kernel change}{table.caption.18}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S4}{\ignorespaces FashionMNIST binary classification. The Spearman correlation between kernel change and generalization improvement is \emph  {negative} (Spearman $\rho =-0.43$, $p=0.017$). See Section~4.4 for discussion.}}{32}{table.caption.19}\protected@file@percent }
\newlabel{fig:fashion}{{S4}{32}{FashionMNIST binary classification. The Spearman correlation between kernel change and generalization improvement is \emph {negative} (Spearman $\rho =-0.43$, $p=0.017$). See Section~4.4 for discussion}{table.caption.19}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S5}{\ignorespaces Random-label baseline (poly target, shuffled labels). Kernel change remains substantial at small widths despite the absence of any signal, demonstrating that large Frobenius change alone cannot distinguish signal-driven adaptation from noise. Results are means over 5 seeds.}}{32}{table.caption.20}\protected@file@percent }
\newlabel{tab:random_label}{{S5}{32}{Random-label baseline (poly target, shuffled labels). Kernel change remains substantial at small widths despite the absence of any signal, demonstrating that large Frobenius change alone cannot distinguish signal-driven adaptation from noise. Results are means over 5 seeds}{table.caption.20}{}}
