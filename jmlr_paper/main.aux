\@writefile{toc}{\contentsline {subsection}{\numberline {5.1}Implications for understanding feature learning}{16}{subsection.5.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {RDEP Reliability Map.} Observable kernel diagnostics enter three reliability regimes where common interpretations fail. Regime~I: high CKA does not imply sufficient representation. Regime~II: large Frobenius change does not imply useful task adaptation. Regime~III: CKA $>0.99$ coexists with substantial spectral reorganization. Below the regimes, a predictive framework (Section~5.1.1) shows that regime membership can be anticipated from headroom ($1-R^2_{\text  {init}}$) and spectral alignment (in-sample $R^2=0.847$, LOOCV $R^2=0.710$), but instance-level corrections (Section~5.2) reveal a deeper validation gap ($\rho =-0.45$).}}{17}{figure.caption.6}\protected@file@percent }
\newlabel{fig:reliability_map}{{4}{17}{\textbf {RDEP Reliability Map.} Observable kernel diagnostics enter three reliability regimes where common interpretations fail. Regime~I: high CKA does not imply sufficient representation. Regime~II: large Frobenius change does not imply useful task adaptation. Regime~III: CKA $>0.99$ coexists with substantial spectral reorganization. Below the regimes, a predictive framework (Section~5.1.1) shows that regime membership can be anticipated from headroom ($1-R^2_{\text {init}}$) and spectral alignment (in-sample $R^2=0.847$, LOOCV $R^2=0.710$), but instance-level corrections (Section~5.2) reveal a deeper validation gap ($\rho =-0.45$)}{figure.caption.6}{}}
